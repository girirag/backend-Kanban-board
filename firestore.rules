rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // kanban-tasks: owner can read/write their own tasks;
    // collaborators can read/write tasks belonging to boards they've been invited to
    match /kanban-tasks/{taskId} {
      allow read, write: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        exists(/databases/$(database)/documents/collaborations/$(request.auth.uid + '_' + resource.data.userId)) ||
        exists(/databases/$(database)/documents/collaborations/$(resource.data.userId + '_' + request.auth.uid))
      );
      // Fallback: allow if a collaboration record exists for this user as collaborator
      allow read, write: if request.auth != null &&
        resource.data.userId != null &&
        firestore.exists(/databases/$(database)/documents/collaborations) == false;
    }

    // users: any authenticated user can read; users can only write their own record
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // collaborations: owner can read/write their own invites;
    // collaborator can read invites where they are the collaborator
    match /collaborations/{inviteId} {
      allow read, write: if request.auth != null && (
        resource.data.ownerUserId == request.auth.uid ||
        resource.data.collaboratorUid == request.auth.uid
      );
      allow create: if request.auth != null &&
        request.resource.data.ownerUserId == request.auth.uid;
    }

    // Legacy tasks collection
    match /tasks/{taskId} {
      allow read, write: if request.auth != null;
    }
  }
}
